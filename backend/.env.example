# Copy to backend/.env and fill in real values. backend/.env is gitignored.

# MongoDB Atlas SRV connection string, including the database name:
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/teamboard?retryWrites=true&w=majority

# JWT signing secret — generate a long random string, e.g. `openssl rand -hex 32`:
JWT_SECRET=replace-with-a-long-random-secret-at-least-16-chars

# Token lifetime (zeit/ms format):
JWT_EXPIRES_IN=7d

# Local dev port:
PORT=4000

# Allowed frontend origin(s), comma-separated:
CORS_ORIGIN=http://localhost:5173

# Node environment:
NODE_ENV=development
