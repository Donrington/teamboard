# Root-level reference for the values each workspace needs.
# Copy the relevant lines into backend/.env and frontend/.env (both gitignored).
# NEVER commit real secrets — only this .example file (with placeholders) is tracked.

# --- Backend (backend/.env) ---
# Full Atlas SRV connection string, including the database name:
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/teamboard?retryWrites=true&w=majority
# Secret used to sign JWTs — use a long random string (openssl rand -hex 32):
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
PORT=4000
# Comma-separated list of origins allowed to call the API:
CORS_ORIGIN=http://localhost:5173

# --- Frontend (frontend/.env) ---
# Base URL of the backend API, including the /api prefix:
VITE_API_URL=http://localhost:4000/api
