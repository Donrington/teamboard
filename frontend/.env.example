# Copy to frontend/.env (gitignored). Base URL of the backend API, including /api:
VITE_API_URL=http://localhost:4000/api

# Optional — enables avatar uploads on the Settings page via Cloudinary's direct,
# unsigned upload API (docs/07-settings). Create a free Cloudinary account, then in
# Settings > Upload > Upload presets, add an *unsigned* preset (restrict it to images,
# a folder, and a size cap). Both of these values are public/non-secret by design.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
